{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["vue"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-underscore-dangle": [
      "warn",
      {
        "allow": ["__format", "_config", "_createEditorArgs", "_nodes", "_onError", "_parentEditor"]
      }
    ]
  },
  "ignorePatterns": ["dist/**", "coverage/**"]
}
