{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["vue"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-underscore-dangle": [
      "warn",
      {
        "allow": [
          "__format",
          "__lexicalEditor",
          "_commands",
          "_config",
          "_createEditorArgs",
          "_nodeMap",
          "_nodes",
          "_onError",
          "_parentEditor"
        ]
      }
    ]
  },
  "ignorePatterns": ["dist/**", "coverage/**"]
}
